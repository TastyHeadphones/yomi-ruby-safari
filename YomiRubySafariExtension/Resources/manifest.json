{
  "manifest_version": 2,
  "name": "Yomi Ruby Safari",
  "version": "1.0.0",
  "description": "Annotate Japanese text on the current page with furigana ruby tags using local kuromoji/IPADIC dictionary data.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "background": {
    "scripts": [
      "kuromoji.js",
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "local-dict.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_title": "Yomi Ruby",
    "default_popup": "popup.html"
  }
}
